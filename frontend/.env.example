# Frontend configuration — copy to `.env` (or `.env.production`) when needed.

# Base URL the frontend uses to reach the backend API.
#  - DEV: leave unset — defaults to http://localhost:4009/api
#  - PROD (backend reverse-proxied on same domain via Nginx): set to /api
#  - PROD (separate API host): set to the full URL, e.g. https://api.yourdomain.com/api
# VITE_API_URL=/api
