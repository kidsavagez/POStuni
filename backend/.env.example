# Backend configuration — copy this file to `.env` and adjust values.
# In dev you can leave most of these as-is.

# Port the API server listens on
PORT=4009

# Secret used to sign JWT auth tokens. CHANGE THIS to a long random string in production.
JWT_SECRET=your_super_secret_jwt_key_change_this

# Telegram bot (optional) — leave blank to disable order notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# CORS allowed origin.
#  - PRODUCTION: set to your deployed frontend URL, e.g. https://orders.yourdomain.com
#  - DEV: leave commented out — the backend then accepts any http://localhost:<port>
#    origin (handy when Vite shifts from 5173 to 5174, etc.)
# FRONTEND_URL=https://orders.yourdomain.com
